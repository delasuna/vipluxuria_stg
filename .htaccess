# === ATIVA REESCRITA DE URL ===
RewriteEngine On
RewriteBase /

# Se o arquivo ou diretório NÃO existe
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Redireciona para a home
ErrorDocument 404 /pagina-nao-encontrada.php

# === PERFIS ===
RewriteRule ^perfil/([0-9]+)/([a-z0-9-]+)/?$ /conteudo/perfil.php?id=$1&nome=$2 [NC]
RewriteRule ^perfil-homens/([0-9]+)/([a-z0-9-]+)/?$ conteudo/perfil-homens.php?id=$1&nome=$2 [NC,L]
RewriteRule ^perfil-transex/([0-9]+)/([a-z0-9-]+)/?$ conteudo/perfil-transex.php?id=$1&nome=$2 [NC,L]

# === GUIA MOTEIS ===
RewriteRule ^guia-moteis-porto-alegre-poa/?$ guia_moteis/guia_moteis_a.php [NC,L]
