# === OUTRAS PÁGINAS ===
RewriteRule ^como-anunciar/?$ como_anunciar.php [NC,L]
RewriteRule ^lojas-sexshops-porto-alegre-poa/?$ lojas_sexshops.php [NC,L]
RewriteRule ^parceiros/?$ parceiros.php [NC,L]
RewriteRule ^swing-porto-alegre-poa/?$ swing.php [NC,L]
RewriteRule ^vip-enquetes/?$ vip_enquetes.php [NC,L]
RewriteRule ^vip-transportes/?$ vip_transportes.php [NC,L]
RewriteRule ^vip-recomenda/?$ vip_recomenda.php [NC,L]
RewriteRule ^tutorial/?$ tutorial.php [NC,L]
