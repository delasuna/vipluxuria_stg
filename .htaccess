# === MURAL DE RECADOS ===
RewriteRule ^mural-recados/?$ mural_recados.php [NC,L]
RewriteRule ^mural-recados/([0-9]+)/?$ mural_recados.php?pagina=$1 [NC,L]

# === BLOG ===
RewriteRule ^vip-blog/?$ vip_blog.php [NC,L]
RewriteRule ^vip-blog/([0-9]+)/?$ vip_blog.php?pagina=$1 [NC,L]
RewriteRule ^vip-blog-post/([0-9]+)/([a-z0-9-]+)/?$ vip_blog-post.php?idBlog=$1&assunto=$2 [NC,L]

# === CLASSIFICADOS ===
RewriteRule ^classificados/?$ classificados.php [NC,L]
RewriteRule ^classificados/([0-9]+)/?$ classificados.php?pagina=$1 [NC,L]

# === MULHERES/ACOMPANHANTES ===
RewriteRule ^mulheres-acompanhantes-porto-alegre-poa/?$ conteudo/mulheres.php [NC,L]
RewriteRule ^casais-e-homens-porto-alegre-poa/?$ conteudo/casais-e-homens.php [NC,L]
RewriteRule ^transex-porto-alegre-poa/?$ conteudo/transex.php [NC,L]

RewriteRule ^Acompanhantes-([a-z0-9-]+)/?$ conteudo/mulheres.php?flagTipo=$1 [NC,L]
RewriteRule ^Acompanhantes/([0-9]+)/([a-z0-9-]+)/?$ conteudo/mulheres.php?idCidade=$1&nomeCidade=$2 [NC,L]
